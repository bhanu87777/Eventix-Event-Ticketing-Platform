# ─────────────────────────────────────────────────────────────
# Eventix backend — environment configuration
# Copy this file to `backend/.env` and adjust as needed.
# NEVER commit your real `.env` — only this example is tracked.
# In production, provide these values via the environment, not a file.
# ─────────────────────────────────────────────────────────────

# HTTP port the API listens on.
PORT=3000

# Secret used to sign auth JWTs. Generate a strong one:  openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-change-me

# Secret used to HMAC-sign ticket QR payloads (ETP1.<code>.<hmac>).
# Must be strong and kept private — it is what makes QR codes unforgeable.
TICKET_SECRET=dev-ticket-hmac-secret-change-me

# Database mode:
#   EMBEDDED_PG=1  → the server boots its own PostgreSQL (no Docker needed).
#   EMBEDDED_PG=0  → use an external Postgres; run `docker compose up -d` first.
EMBEDDED_PG=1

# PostgreSQL connection string.
# With EMBEDDED_PG=1 this points at the bundled instance (port 5433 by default).
DATABASE_URL=postgres://postgres:postgres@localhost:5433/tickets
